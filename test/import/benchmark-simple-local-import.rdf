    <!-- https://raw.githubusercontent.com/iofoundry/ontopuml/refs/heads/main/test/import/benchmark-simple.rdf/DataAllComplexDatatypeClass -->

    <owl:Class rdf:about="https://raw.githubusercontent.com/iofoundry/ontopuml/refs/heads/main/test/import/benchmark-simple.rdf/DataAllComplexDatatypeClass">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://nist.gov/nowl/benchmark-core/simpleDataProperty3"/>
                <owl:allValuesFrom>
                    <rdfs:Datatype>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdfs:Datatype>
                                <owl:datatypeComplementOf>
                                    <rdfs:Datatype>
                                        <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
                                        <owl:withRestrictions rdf:parseType="Collection">
                                            <rdf:Description>
                                                <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">5.0</xsd:minInclusive>
                                            </rdf:Description>
                                        </owl:withRestrictions>
                                    </rdfs:Datatype>
                                </owl:datatypeComplementOf>
                            </rdfs:Datatype>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.5</xsd:minExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:intersectionOf>
                    </rdfs:Datatype>
                </owl:allValuesFrom>
            </owl:Restriction>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- https://raw.githubusercontent.com/iofoundry/ontopuml/refs/heads/main/test/import/benchmark-simple.rdf/DataAllDatatypeOneOfClass -->

    <owl:Class rdf:about="https://raw.githubusercontent.com/iofoundry/ontopuml/refs/heads/main/test/import/benchmark-simple.rdf/DataAllDatatypeOneOfClass">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://nist.gov/nowl/benchmark-core/simpleDataProperty1"/>
                <owl:allValuesFrom>
                    <rdfs:Datatype>
                        <owl:oneOf>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</rdf:first>
                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </owl:oneOf>
                    </rdfs:Datatype>
                </owl:allValuesFrom>
            </owl:Restriction>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- https://raw.githubusercontent.com/iofoundry/ontopuml/refs/heads/main/test/import/benchmark-simple.rdf/DataAllDatatypeRangeClass -->

    <owl:Class rdf:about="https://raw.githubusercontent.com/iofoundry/ontopuml/refs/heads/main/test/import/benchmark-simple.rdf/DataAllDatatypeRangeClass">
        <owl:equivalentClass>
