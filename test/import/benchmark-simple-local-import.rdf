    <!-- https://raw.githubusercontent.com/iofoundry/ontopuml/refs/heads/main/test/import/benchmark-simple.rdf/DataSomeComplexDatatypeClass -->

    <owl:Class rdf:about="https://raw.githubusercontent.com/iofoundry/ontopuml/refs/heads/main/test/import/benchmark-simple.rdf/DataSomeComplexDatatypeClass">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://nist.gov/nowl/benchmark-core/simpleDataProperty3"/>
                <owl:someValuesFrom>
                    <rdfs:Datatype>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">100.0</xsd:minInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">-0.5</xsd:minExclusive>
                                    </rdf:Description>
                                    <rdf:Description>
                                        <xsd:maxExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">33.4</xsd:maxExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:unionOf>
                    </rdfs:Datatype>
                </owl:someValuesFrom>
            </owl:Restriction>
        </owl:equivalentClass>
    </owl:Class>
    


