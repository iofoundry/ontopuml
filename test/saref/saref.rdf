    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2001/XMLSchema#date -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2004/02/skos/core#broader -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#broader">
        <owl:inverseOf rdf:resource="http://www.w3.org/2004/02/skos/core#narrower"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#narrower -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#narrower"/>
    


    <!-- https://saref.etsi.org/core/accomplishes -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/accomplishes">
        <owl:inverseOf rdf:resource="https://saref.etsi.org/core/isAccomplishedBy"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/Task"/>
        <rdfs:comment xml:lang="en">Links a certain entity (e.g., a device) to the task it accomplishes.</rdfs:comment>
        <rdfs:label xml:lang="en">accomplishes</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/consistsOf -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/consistsOf">
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/consistsOf"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasFeatureKind"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/consistsOf"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasPropertyKind"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/consistsOf"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasStateKind"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/consistsOf"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/isValueOfProperty"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/consistsOf"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/isValueOfState"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="en">A relationship indicating a composite entity that consists of other entities (e.g., a temperature/humidity sensor that consists of a temperature sensor and a humidity sensor)</rdfs:comment>
        <rdfs:label xml:lang="en">consists of</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Add local restrictions on consistsOf on feature of interest</skos:historyNote>
        <skos:note xml:lang="en">A feature kind (respectively a feature of interest) may consist of (OP saref:consistsOf) other feature kinds (respectively feature kinds or features of interest).</skos:note>
        <skos:note xml:lang="en">The OP saref:consistsOf can link a composite property, property of interest, or property value to its individual components.</skos:note>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/consumes -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/consumes">
        <owl:inverseOf rdf:resource="https://saref.etsi.org/core/isConsumedBy"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Device"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/DeviceKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/Commodity"/>
        <rdfs:comment xml:lang="en">Links a feature kind, feature of interest, or device, to the commodity it consumes</rdfs:comment>
        <rdfs:label xml:lang="en">consumes</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced saref:consumes, saref:isConsumedBy, saref:produces, saref:isProducedBy, saref:stores, saref:isStoredBy.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/controls -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/controls">
        <rdfs:subPropertyOf rdf:resource="https://saref.etsi.org/core/targets"/>
        <owl:inverseOf rdf:resource="https://saref.etsi.org/core/isControlledBy"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Actuation"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Actuator"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Command"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/CommandOfInterest"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/DeviceKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Function"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FunctionOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:comment xml:lang="en">Links a device, function, command, or procedure execution, to the feature, property, or state, it controls.</rdfs:comment>
        <rdfs:label xml:lang="en">controls</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced property saref:controls, as sub-property of saref:targets. and generalization of saref:controlsProperty.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasApplicableTime -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasApplicableTime">
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2006/time#TemporalEntity"/>
                    <rdf:Description rdf:about="http://www.w3.org/2006/time#TemporalPosition"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links an entity (e.g., a profile) to an instant or interval or other compound temporal entity expressed using OWL Time, which bounds temporally the applicable context of that entity.</rdfs:comment>
        <rdfs:label xml:lang="en">has applicable time</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasCommand -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasCommand">
        <owl:inverseOf rdf:resource="https://saref.etsi.org/core/isCommandOf"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Function"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FunctionOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/Command"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasCommandOfInterest"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasCommandKind"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasFeatureKind"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasMandatoryCommand"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="en">Links a function or function of interest and the command it supports.</rdfs:comment>
        <rdfs:label xml:lang="en">has command</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Domain of saref:hasCommand is relaxed to saref:Function or saref:FunctionOfInterest.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasCommandKind -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasCommandKind">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/CommandOfInterest"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/Command"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasCommandKind"/>
            <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#broader"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="en">links a command of interest to its kind, a command.</rdfs:comment>
        <rdfs:label xml:lang="en">has command kind</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasCommandOfInterest -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasCommandOfInterest">
        <owl:inverseOf rdf:resource="https://saref.etsi.org/core/isCommandOfInterestOf"/>
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/FunctionOfInterest"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/CommandOfInterest"/>
        <rdfs:comment xml:lang="en">Links a function of interest to one of its commands of interest.</rdfs:comment>
        <rdfs:label xml:lang="en">has command of interest</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasDeviceKind -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasDeviceKind">
        <rdfs:subPropertyOf rdf:resource="https://saref.etsi.org/core/hasFeatureKind"/>
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/Device"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/DeviceKind"/>
        <rdfs:comment xml:lang="en">Links a device to its kind, a device kind. Kinds of devices describe models of devices, with common properties and common states having the same value, targeting the same properties and states, common functions, and common services.</rdfs:comment>
        <rdfs:label xml:lang="en">has device kind</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasFeatureKind -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasFeatureKind">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/FeatureOfInterest"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/FeatureKind"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasFeatureKind"/>
            <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#broader"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="en">links a feature of interest to its kind, a feature kind</rdfs:comment>
        <rdfs:label xml:lang="en">has feature kind</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduce hasClassKind for Class is Feature, Device, Property, State, Function, Command.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasFunction -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasFunction">
        <owl:inverseOf rdf:resource="https://saref.etsi.org/core/isFunctionOf"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/Function"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#broader"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasFunction"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasDeviceKind"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasFunction"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasFunctionOfInterest"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasFunctionKind"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="en">Links a feature kind or a device to one of its functions.</rdfs:comment>
        <rdfs:label xml:lang="en">has function</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Domain of saref:hasFunction is relaxed.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasFunctionKind -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasFunctionKind">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/FunctionOfInterest"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/Function"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasFunctionKind"/>
            <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#broader"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="en">links a function of interest to its kind, a function</rdfs:comment>
        <rdfs:label xml:lang="en">has function kind</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasFunctionOfInterest -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasFunctionOfInterest">
        <owl:inverseOf rdf:resource="https://saref.etsi.org/core/isFunctionOfInterestOf"/>
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/Device"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/FunctionOfInterest"/>
        <rdfs:comment xml:lang="en">Links a device to one of its functions of interest.</rdfs:comment>
        <rdfs:label xml:lang="en">has function of interest</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasInput -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasInput">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Command"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/CommandOfInterest"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Operation"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/ProcedureExecution"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:comment xml:lang="en">Links a command, operation, or procedure execution, to its inputs.</rdfs:comment>
        <rdfs:label xml:lang="en">has input</rdfs:label>
        <skos:example xml:lang="en">Different complementary commands can be defined for controlling a light. Turn on or off the light based on a desired state, toggle the light status of a specific light, set the luminosity level with a transition time, set the default transition time, start comfort.</skos:example>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced saref:hasInput and saref:hasOutput.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasMandatoryCommand -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasMandatoryCommand">
        <rdfs:subPropertyOf rdf:resource="https://saref.etsi.org/core/hasCommand"/>
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/Function"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#broader"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasMandatoryCommand"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="en">Links a function and one of its mandatory commands</rdfs:comment>
        <rdfs:label xml:lang="en">has mandatory command</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced mandatory and optional commands.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasOperation -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasOperation">
        <owl:inverseOf rdf:resource="https://saref.etsi.org/core/isOperationOf"/>
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/Service"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/Operation"/>
        <rdfs:comment xml:lang="en">Links a service to one of its operations.</rdfs:comment>
        <rdfs:label xml:lang="en">has operation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasOptionalCommand -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasOptionalCommand">
        <rdfs:subPropertyOf rdf:resource="https://saref.etsi.org/core/hasCommand"/>
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/Function"/>
        <rdfs:comment xml:lang="en">Links a function and one of its optional commands</rdfs:comment>
        <rdfs:label xml:lang="en">has optional command</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasOutput -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasOutput">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Command"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/CommandOfInterest"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Operation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:comment xml:lang="en">Links a command or operation to its outputs.</rdfs:comment>
        <rdfs:label xml:lang="en">has output</rdfs:label>
        <skos:example xml:lang="en">Different complementary commands can be defined for observing a smart home. Observe the temperature once will output the indoor temperature property; observe status of the entry door will output an open/close state.</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasPhenomenonTime -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasPhenomenonTime">
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <rdfs:comment xml:lang="en">Links a procedure execution to the time that the result applies. It may be an interval or an instant, or some other compound temporal entity expressed using OWL Time.</rdfs:comment>
        <rdfs:label xml:lang="en">has phenomenon time</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced saref:hasPhenomenonTime as part of general will to make SAREF and SOSA/SSN converge.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasProfile -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasProfile">
        <owl:inverseOf rdf:resource="https://saref.etsi.org/core/isProfileOf"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Device"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/DeviceKind"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/Profile"/>
        <rdfs:comment xml:lang="en">Links a device to its profile. Its inverse is saref:isProfileOf. The device should be linked to a certain commodity using OP saref:consumes, saref:produces, or saref:stores, and optionally to some property or state using OP saref:targets or its sub-properties.</rdfs:comment>
        <rdfs:label xml:lang="en">has profile</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Relaxed domain of saref:hasProfile to saref:FeatureKind or saref:Device</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasProperty -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasProperty">
        <owl:inverseOf rdf:resource="https://saref.etsi.org/core/isPropertyOf"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/Property"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#broader"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasProperty"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasFeatureKind"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasProperty"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasProperty"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/consistsOf"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasPropertyOfInterest"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasPropertyKind"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="en">Links a feature kind or a feature of interest to one of its properties.</rdfs:comment>
        <rdfs:label xml:lang="en">has property</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: applicability of saref:hasProperty is relaxed to also saref:FeatureKind</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasPropertyKind -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasPropertyKind">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/PropertyOfInterest"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/Property"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasPropertyKind"/>
            <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#broader"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="en">links a property of interest to its kind, a property.</rdfs:comment>
        <rdfs:label xml:lang="en">has property kind</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasPropertyOfInterest -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasPropertyOfInterest">
        <owl:inverseOf rdf:resource="https://saref.etsi.org/core/isPropertyOfInterestOf"/>
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/FeatureOfInterest"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/PropertyOfInterest"/>
        <rdfs:comment xml:lang="en">Links a feature of interest to one of its properties of interest.</rdfs:comment>
        <rdfs:label xml:lang="en">has property of interest</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced saref:hasPropertyOfInterest and saref:isPropertyOfInterestOf. Cannot use saref:hasProperty due to the combination of cardinality restrictions and sub-property chain axioms makes the ontology exist the OWL 2 DL prodile.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasPropertyValue -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasPropertyValue">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/PropertyOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/PropertyValue"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#broader"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasPropertyValue"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="en">Links a feature kind, a feature of interest, or a property of interest, to a property value.</rdfs:comment>
        <rdfs:label xml:lang="en">has property value</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced saref:hasPropertyValue.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasResult -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasResult">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/ProcedureExecution"/>
        <rdfs:comment xml:lang="en">Links a procedure execution (e.g., an observation) to its result (e.g., a property value).</rdfs:comment>
        <rdfs:label xml:lang="en">has result</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced saref:hasResult as part of general will to make SAREF and SOSA/SSN converge.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasState -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasState">
        <owl:inverseOf rdf:resource="https://saref.etsi.org/core/isStateOf"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/StateOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/State"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#broader"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasState"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasFeatureKind"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasState"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasStateOfInterest"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasStateKind"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="en">Links a feature kind or a feature of interest to one of its states.</rdfs:comment>
        <rdfs:label xml:lang="en">has state</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Relaxed domain of saref:hasState.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasStateKind -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasStateKind">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/StateOfInterest"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/State"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasStateKind"/>
            <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#broader"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="en">links a state of interest to its kind, a state</rdfs:comment>
        <rdfs:label xml:lang="en">has state kind</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasStateOfInterest -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasStateOfInterest">
        <owl:inverseOf rdf:resource="https://saref.etsi.org/core/isStateOfInterestOf"/>
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/FeatureOfInterest"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/StateOfInterest"/>
        <rdfs:comment xml:lang="en">Links a feature of interest to one of its states of interest.</rdfs:comment>
        <rdfs:label xml:lang="en">has state of interest</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced saref:hasStateOfInterest and saref:isStateOfInterestOf, parallel to saref:hasPropertyOfInterest and saref:isPropertyOfInterestOf.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/hasStateValue -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/hasStateValue">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/StateOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/StateValue"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#broader"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasStateValue"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="en">Links a feature kind, a feature of interest, or a state of interest, to a state value.</rdfs:comment>
        <rdfs:label xml:lang="en">has state value</rdfs:label>
        <skos:historyNote xml:lang="en">V4.1.1: Introduced saref:hasStateValue.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isAccomplishedBy -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isAccomplishedBy">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/Task"/>
        <rdfs:comment xml:lang="en">A relationship identifying an entity (e.g., a device) that can accomplish a task.</rdfs:comment>
        <rdfs:label xml:lang="en">is accomplished by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isCommandOf -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isCommandOf">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/Command"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Function"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FunctionOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links a command and a function or function of interest that supports it.</rdfs:comment>
        <rdfs:label xml:lang="en">is command of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isCommandOfInterestOf -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isCommandOfInterestOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/CommandOfInterest"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/FunctionOfInterest"/>
        <rdfs:comment xml:lang="en">Links a command of interest to the function of interest it is a command of.</rdfs:comment>
        <rdfs:label xml:lang="en">is command of interest of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isConsumedBy -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isConsumedBy">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/Commodity"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Device"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/DeviceKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links a commodity to the feature kind, feature of interest, or device, that consumes it</rdfs:comment>
        <rdfs:label xml:lang="en">is consumed by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isControlledBy -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isControlledBy">
        <rdfs:subPropertyOf rdf:resource="https://saref.etsi.org/core/isTargetOf"/>
        <rdfs:comment xml:lang="en">Links a feature, property, or state, to the device, function, command, or procedure execution, that controls it.</rdfs:comment>
        <rdfs:label xml:lang="en">is controlled by</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced property saref:isControlledBy.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isExecutionOf -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isExecutionOf">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/ProcedureExecution"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Command"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/CommandOfInterest"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Operation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/isExecutionOf"/>
            <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#broader"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/isExecutionOf"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasCommandKind"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="en">Links a command execution to the command or command of interest that was executed. Also liks an operation execution to the operation that was executed</rdfs:comment>
        <rdfs:label xml:lang="en">is execution of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isFunctionOf -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isFunctionOf">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/Function"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links a function to the feature kind or device it is a function of.</rdfs:comment>
        <rdfs:label xml:lang="en">is function of</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced saref:isFunctionOf.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isFunctionOfInterestOf -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isFunctionOfInterestOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/FunctionOfInterest"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/Device"/>
        <rdfs:comment xml:lang="en">Links a function of interest to the device it is a function of.</rdfs:comment>
        <rdfs:label xml:lang="en">is function of interest of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isMeasuredIn -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isMeasuredIn">
        <rdfs:range rdf:resource="https://saref.etsi.org/core/UnitOfMeasure"/>
        <rdfs:comment xml:lang="en">A relationship identifying the unit of measure used for a certain entity.</rdfs:comment>
        <rdfs:label xml:lang="en">is measured in</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Relaxed domain of saref:isMeasuredIn so it can apply to saref:PropertyValue as well as saref:Measurement. The new range will be enforced in the next major revision of SAREF.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isObservedBy -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isObservedBy">
        <rdfs:subPropertyOf rdf:resource="https://saref.etsi.org/core/isTargetOf"/>
        <owl:inverseOf rdf:resource="https://saref.etsi.org/core/observes"/>
        <rdfs:comment xml:lang="en">Links a feature, property, or state, to the device, function, command, or procedure execution, that observes it.</rdfs:comment>
        <rdfs:label xml:lang="en">is observed by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isOfferedBy -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isOfferedBy">
        <owl:inverseOf rdf:resource="https://saref.etsi.org/core/offers"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/Service"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/Device"/>
        <rdfs:comment xml:lang="en">Links a service to the device that exposes it to a network</rdfs:comment>
        <rdfs:label xml:lang="en">is offered by</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Clarified definition of saref:isOfferedBy.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isOperationOf -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isOperationOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/Operation"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/Service"/>
        <rdfs:comment xml:lang="en">Links an operation to the service it belongs to.</rdfs:comment>
        <rdfs:label xml:lang="en">is operation of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isProducedBy -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isProducedBy">
        <owl:inverseOf rdf:resource="https://saref.etsi.org/core/produces"/>
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/Commodity"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Device"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/DeviceKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links a commodity to the feature kind, feature of interest, or device, that produces it</rdfs:comment>
        <rdfs:label xml:lang="en">is produced by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isProfileOf -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isProfileOf">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/Profile"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Device"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/DeviceKind"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links a profile to the device it describes. The device should be linked to a certain commodity using OP saref:consumes, saref:produces, or saref:stores, and optionally to some property or state using OP saref:targets or its sub-properties.</rdfs:comment>
        <rdfs:label xml:lang="en">is profile of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isPropertyOf -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isPropertyOf">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/Property"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links a property to the feature kind or feature of interest it is a property of.</rdfs:comment>
        <rdfs:label xml:lang="en">is property of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isPropertyOfInterestOf -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isPropertyOfInterestOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/PropertyOfInterest"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/FeatureOfInterest"/>
        <rdfs:comment xml:lang="en">Links a property of interest to the feature of interest it is a property of.</rdfs:comment>
        <rdfs:label xml:lang="en">is property of interest of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isStateOf -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isStateOf">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/State"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links a state to the feature kind or feature of interest it is a state of.</rdfs:comment>
        <rdfs:label xml:lang="en">is state of</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced saref:isStateOf.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isStateOfInterestOf -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isStateOfInterestOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/StateOfInterest"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/FeatureOfInterest"/>
        <rdfs:comment xml:lang="en">Links a state of interest to the feature of interest it is a state of.</rdfs:comment>
        <rdfs:label xml:lang="en">is state of interest of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isStoredBy -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isStoredBy">
        <owl:inverseOf rdf:resource="https://saref.etsi.org/core/stores"/>
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/Commodity"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Device"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/DeviceKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links a commodity to the feature kind, feature of interest, or device, that stores it</rdfs:comment>
        <rdfs:label xml:lang="en">is stored by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isTargetOf -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isTargetOf">
        <owl:inverseOf rdf:resource="https://saref.etsi.org/core/targets"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Property"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/PropertyOfInterest"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/State"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/StateOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Command"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/CommandOfInterest"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Device"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/DeviceKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Function"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FunctionOfInterest"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/ProcedureExecution"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links a feature, property, or state, to the device, function, command, or procedure execution, that targets it.</rdfs:comment>
        <rdfs:label xml:lang="en">is target of</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced property saref:isActedUponBy.</skos:historyNote>
        <skos:historyNote xml:lang="en">V4.1.1: Renamed property saref:isActedUponBy into saref:isTargetOf.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isValueOfProperty -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isValueOfProperty">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/PropertyValue"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Property"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/PropertyOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/isValueOfProperty"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasPropertyKind"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="en">Links a property value to the property or property of interest it is a value of.</rdfs:comment>
        <rdfs:label xml:lang="en">is value of property</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced saref:isValueOfProperty.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/isValueOfState -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/isValueOfState">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/StateValue"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/StateOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://saref.etsi.org/core/isValueOfState"/>
            <rdf:Description rdf:about="https://saref.etsi.org/core/hasStateKind"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="en">Links a state value to the state or state of interest it is a value of.</rdfs:comment>
        <rdfs:label xml:lang="en">is value of state</rdfs:label>
        <skos:historyNote xml:lang="en">V4.1.1: Introduced saref:isValueOfState.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/madeBy -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/madeBy">
        <owl:inverseOf rdf:resource="https://saref.etsi.org/core/madeExecution"/>
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/ProcedureExecution"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/FeatureOfInterest"/>
        <rdfs:comment xml:lang="en">Links a procedure execution to the entity (e.g., device) that made it.</rdfs:comment>
        <rdfs:label xml:lang="en">made by</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduce saref:madeBy (resp. saref:madeExecution) as generalization of saref:measurementMadeBy (resp. saref:makesMeasurement).</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/madeExecution -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/madeExecution">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/FeatureOfInterest"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/ProcedureExecution"/>
        <rdfs:comment xml:lang="en">Links an entity (e.g., device) to the procedure execution it made.</rdfs:comment>
        <rdfs:label xml:lang="en">made execution</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/observes -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/observes">
        <rdfs:subPropertyOf rdf:resource="https://saref.etsi.org/core/targets"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Command"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/CommandOfInterest"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/DeviceKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Function"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FunctionOfInterest"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Observation"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Sensor"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:comment xml:lang="en">Links a device, function, command, or procedure execution, to the feature, property, or state, it observes.</rdfs:comment>
        <rdfs:label xml:lang="en">observes</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced property saref:observes, as sub-property of saref:targets. and generalization of measures.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/offers -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/offers">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/Device"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/Service"/>
        <rdfs:comment xml:lang="en">Links a device to a service it exposes to a network.</rdfs:comment>
        <rdfs:label xml:lang="en">offers</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Clarified definition of saref:offers.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/produces -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/produces">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Device"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/DeviceKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/Commodity"/>
        <rdfs:comment xml:lang="en">Links a feature kind, feature of interest, or device, to the commodity it produces</rdfs:comment>
        <rdfs:label xml:lang="en">produces</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/profileHasPrice -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/profileHasPrice">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/Profile"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/PropertyValue"/>
        <rdfs:comment xml:lang="en">Links a profile to the money earned (negative values) or paid (positive values) for the use (production or consumption) of the commodity by the device</rdfs:comment>
        <rdfs:label xml:lang="en">has price</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/represents -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/represents">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Operation"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Service"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Command"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/CommandOfInterest"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Function"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FunctionOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links a service to some function or function of interest it exposes to the network. Also links an operation to some command or command of interest it exposes to the network.</rdfs:comment>
        <rdfs:label xml:lang="en">represents</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Relaxed domain and range of saref:represents.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/stores -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/stores">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Device"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/DeviceKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/Commodity"/>
        <rdfs:comment xml:lang="en">Links a feature kind, feature of interest, or device, to the commodity it stores</rdfs:comment>
        <rdfs:label xml:lang="en">stores</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/targets -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/targets">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Command"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/CommandOfInterest"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Device"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/DeviceKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Function"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FunctionOfInterest"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/ProcedureExecution"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Property"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/PropertyOfInterest"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/State"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/StateOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links a device, function, command, or procedure execution, to the feature, property, or state, it targets.</rdfs:comment>
        <rdfs:label xml:lang="en">targets</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: saref:actsUpon now holds not only between a command and a state. It generalizes observes, observes, controls. Domain and range are unions of several classes.</skos:historyNote>
        <skos:historyNote xml:lang="en">V4.1.1: saref:actsUpon is renamed saref:targets.</skos:historyNote>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/whenPropertyValue -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/whenPropertyValue">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/Profile"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/PropertyValue"/>
        <rdfs:comment xml:lang="en">Links a profile to a property value that contributes to restricting its applicable context.</rdfs:comment>
        <rdfs:label xml:lang="en">when property value</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://saref.etsi.org/core/whenState -->

    <owl:ObjectProperty rdf:about="https://saref.etsi.org/core/whenState">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/Profile"/>
        <rdfs:range rdf:resource="https://saref.etsi.org/core/State"/>
        <rdfs:comment xml:lang="en">Links a profile to a state that contributes to restricting its applicable context.</rdfs:comment>
        <rdfs:label xml:lang="en">when state</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://saref.etsi.org/core/hasIdentifier -->

    <owl:DatatypeProperty rdf:about="https://saref.etsi.org/core/hasIdentifier">
        <rdfs:comment xml:lang="en">Links some entity to its identifier. Extensions of SAREF may define sub-properties such as s4abcd:hasUUID, s4abcd:hasGTIN12, etc.</rdfs:comment>
        <rdfs:label xml:lang="en">has identifier</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://labs.etsi.org/rep/saref/saref-portal/-/issues/2"/>
    </owl:DatatypeProperty>
    


    <!-- https://saref.etsi.org/core/hasManufacturer -->

    <owl:DatatypeProperty rdf:about="https://saref.etsi.org/core/hasManufacturer">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:comment xml:lang="en">A relationship identifying the manufacturer of an entity (e.g., device). The value is expected to be a string or a string with language tag.</rdfs:comment>
        <rdfs:label xml:lang="en">has manufacturer</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Defined domain of saref:hasManufacturer to union of feature kind and feature of interest.</skos:historyNote>
    </owl:DatatypeProperty>
    


    <!-- https://saref.etsi.org/core/hasModel -->

    <owl:DatatypeProperty rdf:about="https://saref.etsi.org/core/hasModel">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:comment xml:lang="en">A relationship identifying the model of an entity (e.g., device). The value is expected to be a string or a string with language tag.</rdfs:comment>
        <rdfs:label xml:lang="en">has model</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Defined domain of saref:hasModel to union of feature kind and feature of interest.</skos:historyNote>
    </owl:DatatypeProperty>
    


    <!-- https://saref.etsi.org/core/hasResultTime -->

    <owl:DatatypeProperty rdf:about="https://saref.etsi.org/core/hasResultTime">
        <rdfs:domain rdf:resource="https://saref.etsi.org/core/ProcedureExecution"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">Links a procedure execution to the instant of time when the activity was completed, expressed as an xsd:dateTime literal.</rdfs:comment>
        <rdfs:label xml:lang="en">has result time</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced saref:hasResultTime as part of general will to make SAREF and SOSA/SSN converge.</skos:historyNote>
    </owl:DatatypeProperty>
    


    <!-- https://saref.etsi.org/core/hasRevisionNumber -->

    <owl:DatatypeProperty rdf:about="https://saref.etsi.org/core/hasRevisionNumber">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Links some entity (e.g., a device) to its revision number.</rdfs:comment>
        <rdfs:label xml:lang="en">has revision number</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://labs.etsi.org/rep/saref/saref-core/-/issues/53"/>
    </owl:DatatypeProperty>
    


    <!-- https://saref.etsi.org/core/hasTimestamp -->

    <owl:DatatypeProperty rdf:about="https://saref.etsi.org/core/hasTimestamp">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://saref.etsi.org/core/ProcedureExecution"/>
                    <rdf:Description rdf:about="https://saref.etsi.org/core/Profile"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">Links a procedure execution or a profile to an instant.</rdfs:comment>
        <rdfs:label xml:lang="en">has timestamp</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Tried to clarify definition of saref:hasTimestamp. Still unclear.</skos:historyNote>
        <skos:note xml:lang="en">Applied on a profile, it describes the applicable instant of that profile</skos:note>
        <skos:note xml:lang="en">When the execution time and the phenomenon time are the same time instants, then DP saref:hasTimestamp can be used to simply link a procedure execution to the time of these instants, expressed as an xsd:dateTime literal.</skos:note>
    </owl:DatatypeProperty>
    


    <!-- https://saref.etsi.org/core/hasValue -->

    <owl:DatatypeProperty rdf:about="https://saref.etsi.org/core/hasValue">
        <rdfs:comment xml:lang="en">Value of a property value expressed as an RDF literal. Note that, even if decimal values are expected, values could use other datatypes.</rdfs:comment>
        <rdfs:label xml:lang="en">has value</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Clarified definition of saref:hasValue.</skos:historyNote>
    </owl:DatatypeProperty>
    


    <!-- https://saref.etsi.org/core/hasVersion -->

    <owl:DatatypeProperty rdf:about="https://saref.etsi.org/core/hasVersion">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Links some entity (e.g., a device) to its version.</rdfs:comment>
        <rdfs:label xml:lang="en">has version</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://labs.etsi.org/rep/saref/saref-core/-/issues/53"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2006/time#TemporalEntity -->

    <owl:Class rdf:about="http://www.w3.org/2006/time#TemporalEntity"/>
    


    <!-- http://www.w3.org/2006/time#TemporalPosition -->

    <owl:Class rdf:about="http://www.w3.org/2006/time#TemporalPosition"/>
    


    <!-- https://saref.etsi.org/core/Actuation -->

    <owl:Class rdf:about="https://saref.etsi.org/core/Actuation">
        <rdfs:subClassOf rdf:resource="https://saref.etsi.org/core/ProcedureExecution"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/madeBy"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/Actuator"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/controls"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A saref:Actuation is the act of carrying out a procedure to control the state of the world using an actuator. It links to an actuator to describe what made the actuation, and to the controlled feature, property, property of interest, state, or state of interest. Typically, its input is a property value or a state. An actuation of a state (OP saref:controls) should have a state as input (OP saref:hasInput). Respectively, an actuation of a property should have a property value as input.</rdfs:comment>
        <rdfs:label xml:lang="en">Actuation</rdfs:label>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/Actuator -->

    <owl:Class rdf:about="https://saref.etsi.org/core/Actuator">
        <rdfs:subClassOf rdf:resource="https://saref.etsi.org/core/Device"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/controls"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A device designed to control one or more properties or states of one or more features of interest.</rdfs:comment>
        <rdfs:label xml:lang="en">Actuator</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Definition of Actuator is simplified and grounded on saref:controls. Local restriction on saref:hasFunction is deleted.</skos:historyNote>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/Appliance -->

    <owl:Class rdf:about="https://saref.etsi.org/core/Appliance">
        <rdfs:subClassOf rdf:resource="https://saref.etsi.org/core/Device"/>
        <rdfs:comment xml:lang="en">A device designed to accomplish a particular task for occupant use. It consumes, produces, or stores, some commodity.</rdfs:comment>
        <rdfs:label xml:lang="en">Appliance</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Definition of saref:Appliance is grounded on tasks and commodities.</skos:historyNote>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/Command -->

    <owl:Class rdf:about="https://saref.etsi.org/core/Command">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#broader"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/Command"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#narrower"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/Command"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The lowest-level directives a function exposes to some network. Commands can target (OP saref:targets and its sub-properties) features, properties, or states. An instance of saref:Command is independent of any device.</rdfs:comment>
        <rdfs:label xml:lang="en">Command</rdfs:label>
        <skos:example xml:lang="en">Observe property, control property, observe state, control state, invoke action, cancel action, turn on or off, change color, subscribe, publish, etc. are all commands.</skos:example>
        <skos:historyNote xml:lang="en">V3.2.1: Simplified definition and axiomatization of saref:Command. Added examples.</skos:historyNote>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/CommandExecution -->

    <owl:Class rdf:about="https://saref.etsi.org/core/CommandExecution">
        <rdfs:subClassOf rdf:resource="https://saref.etsi.org/core/ProcedureExecution"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/isExecutionOf"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://saref.etsi.org/core/Command"/>
                            <rdf:Description rdf:about="https://saref.etsi.org/core/CommandOfInterest"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Describes the execution of a command. Typically, its inputs and outputs are human understandable and relate to some feature of interest, such as its state (e.g., s4abcd:On), or the value of its temperature (e.g., property value 21.0 °C).</rdfs:comment>
        <rdfs:label xml:lang="en">Command Execution</rdfs:label>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/CommandOfInterest -->

    <owl:Class rdf:about="https://saref.etsi.org/core/CommandOfInterest">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/isCommandOfInterestOf"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The lowest-level directives a device supports and exposes to some network. Commands can target (OP saref:targets and its sub-properties) features, properties, or states. A saref:CommandOfInterest is a directives actually supported by a device and exposed to some network.</rdfs:comment>
        <rdfs:label xml:lang="en">Command Of Interest</rdfs:label>
        <skos:example xml:lang="en">The corridor smart light switch supports a command of kind “turn on/off”, which controls the state of the outdoor light.</skos:example>
        <skos:example xml:lang="en">The smart fridge supports a command of kind “observe temperature”, which observes the temperature of the fridge.</skos:example>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced saref:CommandOfInterest, parallel to saref:PropertyOfInterest.</skos:historyNote>
        <skos:note xml:lang="en">Commands of interest need not always be explicited. It depends on the use case. Typically, commands of interest are useful to specify the actual property of interest or state of interest that is expected as input parameter, output, or that will be targeted.</skos:note>
        <skos:note xml:lang="en">Like for commands, commands of interest may be described in terms of their input parameters, outputs, and which properties or states they target.</skos:note>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/Commodity -->

    <owl:Class rdf:about="https://saref.etsi.org/core/Commodity">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#broader"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/Commodity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#narrower"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/Commodity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A marketable item which may be supplied without qualitative differentiation.</rdfs:comment>
        <rdfs:label xml:lang="en">Commodity</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Definition of saref:Commodity is simplified.</skos:historyNote>
        <skos:historyNote xml:lang="en">V4.1.1: Removed examples of commodity categories.</skos:historyNote>
        <skos:note xml:lang="en">Concepts from existing code lists, vocabularies, and taxonomies, may be used as instances of saref:Commodity, for example from the ISDA taxonomy of commodities, the Standard International Energy product Classification (SIEC), the IRENA Energy Taxonomy or Wikidata.</skos:note>
        <skos:note xml:lang="en">SAREF refers to energy commodities such as electricity, gas, coal and oil.</skos:note>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/Device -->

    <owl:Class rdf:about="https://saref.etsi.org/core/Device">
        <rdfs:subClassOf rdf:resource="https://saref.etsi.org/core/FeatureOfInterest"/>
        <rdfs:subClassOf rdf:resource="https://saref.etsi.org/saref4syst/System"/>
        <rdfs:comment xml:lang="en">A tangible object designed to accomplish a particular task. In order to accomplish this task, the device performs one or more functions. An instance of saref:Device represents one specific real world entity.</rdfs:comment>
        <rdfs:label xml:lang="en">Device</rdfs:label>
        <skos:example xml:lang="en">Examples of devices are a light switch, a temperature sensor, an energy meter, a water flow meter, and a laundry dryer. A laundry dryer is designed to dry laundry, and to accomplish this task it has a start/stop function.</skos:example>
        <skos:example xml:lang="en">For example, a washing machine is designed to wash (task) and to accomplish this task it performs a start and stop function.</skos:example>
        <skos:historyNote xml:lang="en">V3.2.1: Most axioms on saref:Device were useless and have been deleted.</skos:historyNote>
        <skos:historyNote xml:lang="en">V3.2.1: definition of saref:Device clarifies it&apos;s a real world entity.</skos:historyNote>
        <skos:historyNote xml:lang="en">V3.2.1: saref:Device is explicitly a subclass of saref:FeatureOfInterest and s4syst:System.</skos:historyNote>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/DeviceKind -->

    <owl:Class rdf:about="https://saref.etsi.org/core/DeviceKind">
        <rdfs:subClassOf rdf:resource="https://saref.etsi.org/core/FeatureKind"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#broader"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/FeatureKind"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#narrower"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/FeatureKind"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Device kinds allow to describe kinds of devices, with common properties and common states having the same value, targeting the same properties and states, common functions, and common services. Devices kinds may be used to describe models of devices in online catalogues.</rdfs:comment>
        <rdfs:label xml:lang="en">Device kinds</rdfs:label>
        <skos:historyNote xml:lang="en">V4.1.1: Introduced class saref:DeviceKind</skos:historyNote>
        <skos:historyNote xml:lang="en">V4.1.1: Use SKOS to organize generic classes in taxonomies.</skos:historyNote>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/FeatureKind -->

    <owl:Class rdf:about="https://saref.etsi.org/core/FeatureKind">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#broader"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/FeatureKind"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#narrower"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/FeatureKind"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/consistsOf"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/FeatureKind"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Feature kinds allow to describe kinds of features of interest, with common properties having the same value, and common states being the same. An instance of saref:FeatureKind represents an archetype of real world entities, for example to populate product catalogs.</rdfs:comment>
        <rdfs:label xml:lang="en">Feature kinds</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced class saref:FeatureKind</skos:historyNote>
        <skos:historyNote xml:lang="en">V3.2.1: Use SKOS to organize generic classes in taxonomies.</skos:historyNote>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/FeatureOfInterest -->

    <owl:Class rdf:about="https://saref.etsi.org/core/FeatureOfInterest">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/consistsOf"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/FeatureOfInterest"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A feature of interest represents any real world entity from which a property or a state may be targeted, such as observed and controlled. An instance of saref:FeatureOfInterest represents one specific real world entity.</rdfs:comment>
        <rdfs:label xml:lang="en">Feature of interest</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Definition of saref:FeatureOfInterest is clarified, not only properties are measured, but properties and states can be observed and controlled.</skos:historyNote>
        <skos:historyNote xml:lang="en">V3.2.1: Definition of saref:FeatureOfInterest: Clarify it&apos;s a specific real world entity.</skos:historyNote>
        <skos:historyNote xml:lang="en">V3.2.1: Definition of saref:FeatureOfInterest: allValuesFrom axioms are unnecessary and have been deleted.</skos:historyNote>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/Function -->

    <owl:Class rdf:about="https://saref.etsi.org/core/Function">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#broader"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/Function"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#narrower"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/Function"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Logical groups of commands that devices support to accomplish their tasks. Function can target (OP saref:targets and its sub-properties) features, properties, or states. An instance of saref:Function can apply to different devices.</rdfs:comment>
        <rdfs:label xml:lang="en">Function</rdfs:label>
        <skos:example xml:lang="en">To accomplish the task of controlling the light, a smart light switch may have a function for turning on and off the light, and another to set the luminosity of the light.</skos:example>
        <skos:example xml:lang="en">To accomplish the task of sensing the temperature, a temperature sensor should have a sensing function.</skos:example>
        <skos:example xml:lang="en">To accomplish the task of washing clothes, a washing machine should have a function for washing.</skos:example>
        <skos:historyNote xml:lang="en">V3.2.1: Simplified definition and axiomatization of saref:Function. Added examples.</skos:historyNote>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/FunctionOfInterest -->

    <owl:Class rdf:about="https://saref.etsi.org/core/FunctionOfInterest">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/isFunctionOfInterestOf"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Logical groups of commands that devices support to accomplish their tasks. Function can target (OP saref:targets and its sub-properties) features, properties, or states. An instance of saref:FunctionOfInterest is supported by exactly one device.</rdfs:comment>
        <rdfs:label xml:lang="en">Function of Interest</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced saref:FunctionOfInterest, parallel to saref:PropertyOfInterest.</skos:historyNote>
        <skos:note xml:lang="en">A function of interest is the function of (OP saref:isFunctionOfInterestOf) exactly one device.</skos:note>
        <skos:note xml:lang="en">Functions of interest need not always be explicited. It depends on the use case. Typically, functions of interest are useful to specify which command is actually exposed, and which actual property of interest or state of interest it targets.</skos:note>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/Meter -->

    <owl:Class rdf:about="https://saref.etsi.org/core/Meter">
        <rdfs:subClassOf rdf:resource="https://saref.etsi.org/core/Device"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/observes"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A device designed to observe and additionally do some computation and/or display one or more properties of one or more features of interest.</rdfs:comment>
        <rdfs:label xml:lang="en">Meter</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Definition of Meter is simplified and grounded on saref:observes. Local restriction on saref:hasFunction is deleted.</skos:historyNote>
        <skos:historyNote xml:lang="en">V4.1.1: Definition of Sensor and Meter are updated to better distinguish one from the other.</skos:historyNote>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/Observation -->

    <owl:Class rdf:about="https://saref.etsi.org/core/Observation">
        <rdfs:subClassOf rdf:resource="https://saref.etsi.org/core/ProcedureExecution"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/madeBy"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/Sensor"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/observes"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A saref:Observation is the act of carrying out a procedure to estimate or calculate a value of a property of a feature of interest, or a state of a feature of interest. It links to a sensor to describe what made the observation, and to the observed feature, property, property of interest, state, or state of interest. Typically, its result is a property value or a state. An observation of a state (OP saref:observes) should have a state as a result (OP saref:hasResult). Respectively, an observation of a property should have a property value as a result.</rdfs:comment>
        <rdfs:label xml:lang="en">Observation</rdfs:label>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/Operation -->

    <owl:Class rdf:about="https://saref.etsi.org/core/Operation">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/represents"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://saref.etsi.org/core/Command"/>
                            <rdf:Description rdf:about="https://saref.etsi.org/core/CommandOfInterest"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/represents"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://saref.etsi.org/core/CommandOfInterest"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/isOperationOf"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A saref:Operation is the means of a service to communicate in a procedure-type manner over the network (i.e. transmit data to/from other devices). It is the –machine interpretable– exposure of a –human understandable– command to a network.</rdfs:comment>
        <rdfs:label xml:lang="en">Operation</rdfs:label>
        <skos:example xml:lang="en">In the set of operations exposed by a smart light bulb on a given network, one may be dedicated to turn on and off the light and expect a boolean as input. Another one may be dedicated to set the luminosity status and expect a target luminosity level (a byte) and a transition time (encoded on two bytes).</skos:example>
        <skos:example xml:lang="en">In the set of operations exposed by a smart washing machine on a given network, one may be dedicated to set the water temperature for the washing cycle, and expected as input a enumerated value. Another one may be dedicated to start, pause, or stop the washing cycle.</skos:example>
        <skos:example xml:lang="en">To turn on a light, send a CoAP PUT request with CBOR content 0xf5 (true)</skos:example>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced saref:Operation and associated properties from oneM2M base ontology.</skos:historyNote>
        <skos:note xml:lang="en">An operation may be described in terms of its inputs and outputs using OP saref:hasInput and saref:hasOutput. Inputs and outputs of operations typically describe the expected schema or shape of network messages.</skos:note>
        <skos:note xml:lang="en">Typically, a device connected to a given network offers one service for each of its functions of interest, and each service has one operation per command of interest of the function of interest it represents.</skos:note>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/OperationExecution -->

    <owl:Class rdf:about="https://saref.etsi.org/core/OperationExecution">
        <rdfs:subClassOf rdf:resource="https://saref.etsi.org/core/ProcedureExecution"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/isExecutionOf"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/Operation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Describes the execution of an operation in a network: the–machine interpretable–  description of a communication between devices over the network. Typically, its input and result are network messages, that conform to the input and output of the executed operation.</rdfs:comment>
        <rdfs:label xml:lang="en">Operation Execution</rdfs:label>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/ProcedureExecution -->

    <owl:Class rdf:about="https://saref.etsi.org/core/ProcedureExecution">
        <rdfs:comment xml:lang="en">Represents the act of carrying out a procedure.</rdfs:comment>
        <rdfs:label xml:lang="en">Procedure Execution</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced saref:ProcedureExecution.</skos:historyNote>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/Profile -->

    <owl:Class rdf:about="https://saref.etsi.org/core/Profile">
        <rdfs:comment xml:lang="en">A saref:Profile describes the money earned (negative values) or paied (positive values) for the use (production or consumption) of a commodity by a device in a certain context.</rdfs:comment>
        <rdfs:label xml:lang="en">Profile</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Class saref:Profile has been re-specified, to take into account findings from SAREF4ENER V1.2.1.</skos:historyNote>
        <skos:note xml:lang="en">OP saref:hasPrice links a profile to the money earned (negative values) or paid (positive values) for the use (production or consumption) of the commodity by the device.</skos:note>
        <skos:note xml:lang="en">OP saref:hasProfile links a device to its profile. The device should be linked to a certain commodity using OP saref:consumes, saref:produces, or saref:stores, and optionally to some property or state using OP saref:targets or its sub-properties.</skos:note>
        <skos:note xml:lang="en">The applicable context can be restricted to when a feature of interest has a certain state (OPs saref:whenState).</skos:note>
        <skos:note xml:lang="en">The applicable context can be restricted to when the property of a feature of interest has some value (OPs saref:whenPropertyValue)</skos:note>
        <skos:note xml:lang="en">The applicable context of a profile can be bound temporally using DP saref:hasTimestamp or its subproperties defined by SAREF extensions, or OP saref:hasApplicableTime which links to instant or interval or other compound temporal entity expressed using OWL Time.</skos:note>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/Property -->

    <owl:Class rdf:about="https://saref.etsi.org/core/Property">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#broader"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/Property"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#narrower"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/Property"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/consistsOf"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                            <rdf:Description rdf:about="https://saref.etsi.org/core/Property"/>
                            <rdf:Description rdf:about="https://saref.etsi.org/core/State"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Identifiable qualities of features of interest that can be target of devices, such as observed or controlled. A property can apply to different features of interest.</rdfs:comment>
        <rdfs:label xml:lang="en">Property</rdfs:label>
        <skos:example xml:lang="en">Air temperature, pressure, luminance, etc. are all properties.</skos:example>
        <skos:example xml:lang="en">Two examples using the QUDT Quantity Kind vocabulary, and the British Oceanographic Data Centre Parameter Usage Vocabulary.

&lt;https://qudt.org/2.1/vocab/quantitykind/ActiveEnergy&gt; a saref:Property ;
    rdfs:label &quot;Active Energy&quot;@en ;
    rdfs:comment &quot;&quot;Active Energy&quot; is the electrical energy transformable into some other form of energy.&quot;@en .

&lt;http://vocab.nerc.ac.uk/collection/P01/current/CDTSZZ01/&gt; a saref:Property ;
    skos:prefLabel &quot;Absolute temperature standard deviation of the atmosphere by dry bulb thermometer&quot;@en .
</skos:example>
        <skos:historyNote xml:lang="en">Until SAREF V3.1.1, there was an ambiguity between whether properties should be specific or generic to features of interest. This ambiguity has been solved in SAREF V3.2.1, and the new modeling will be enforced in the next major revision of SAREF.</skos:historyNote>
        <skos:historyNote xml:lang="en">V3.2.1: The definition and scope of usage for saref:Property is clarified. Axiomatization is simplified.</skos:historyNote>
        <skos:note xml:lang="en">Concepts from existing code lists, vocabularies, and taxonomies, may be used as instances of saref:Property.</skos:note>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/PropertyOfInterest -->

    <owl:Class rdf:about="https://saref.etsi.org/core/PropertyOfInterest">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/consistsOf"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                            <rdf:Description rdf:about="https://saref.etsi.org/core/Property"/>
                            <rdf:Description rdf:about="https://saref.etsi.org/core/PropertyOfInterest"/>
                            <rdf:Description rdf:about="https://saref.etsi.org/core/State"/>
                            <rdf:Description rdf:about="https://saref.etsi.org/core/StateOfInterest"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/isPropertyOfInterestOf"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Identifiable qualities of features of interest that can be target of devices, such as observed or controlled. An instance of saref:PropertyOfInterest is specific to a feature of interest. It is inherent to and cannot exist without that feature of interest.</rdfs:comment>
        <rdfs:label xml:lang="en">Property of Interest</rdfs:label>
        <skos:example xml:lang="en">The air temperature of the atmosphere sample at a certain location and altitude, the received signal strength indicator of an wireless IoT connection, the luminance of the ETSI ATHENA amphitheatre.

&lt;etsi_premises/athena#luminance&gt; a saref:PropertyOfInterest ;
    saref:isPropertyOfInterestOf &lt;etsi_premises/athena&gt; ;
    saref:hasPropertyKind saref:Luminance ;
    rdfs:comment &quot;The luminance of amphitheatre ATHENA&quot;@en .
</skos:example>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced saref:PropertyOfInterest to solved the ambiguity between generic vs specific properties.</skos:historyNote>
        <skos:note xml:lang="en">A property of interest is the property of (OP saref:isPropertyOfInterestOf) exactly one feature of interest.</skos:note>
        <skos:note xml:lang="en">Per convention, the IRI of properties of interest should consist of the IRI of their feature of interest, suffixed with a fragment identifier #{P} where {P} refers to the name of the property.</skos:note>
        <skos:note xml:lang="en">Properties of interest need not always be explicited. It depends on the use case. Typically, properties of interest are useful in applications, where the association between a feature of interest and a property (i.e., the property of interest) needs to be identified and related to other properties of interest.</skos:note>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/PropertyValue -->

    <owl:Class rdf:about="https://saref.etsi.org/core/PropertyValue">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/consistsOf"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureKind"/>
                            <rdf:Description rdf:about="https://saref.etsi.org/core/FeatureOfInterest"/>
                            <rdf:Description rdf:about="https://saref.etsi.org/core/Property"/>
                            <rdf:Description rdf:about="https://saref.etsi.org/core/PropertyOfInterest"/>
                            <rdf:Description rdf:about="https://saref.etsi.org/core/PropertyValue"/>
                            <rdf:Description rdf:about="https://saref.etsi.org/core/State"/>
                            <rdf:Description rdf:about="https://saref.etsi.org/core/StateOfInterest"/>
                            <rdf:Description rdf:about="https://saref.etsi.org/core/StateValue"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/isMeasuredIn"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/hasValue"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Describes the value for a property. The property value is optionally linked to its value expressed as an RDF literal (DP saref:hasValue), optionally to the unit of measurement (OP saref:isMeasuredIn), and optionally to the properties or properties of interest it is a value of (OP saref:isValueOfProperty).</rdfs:comment>
        <rdfs:label xml:lang="en">Property Value</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced saref:PropertyValue to simplify the association of a measure to a property, without always needing it to be a measurement made by a device.</skos:historyNote>
        <skos:historyNote xml:lang="en">V4.1.1: saref:hasValue is now optional on saref:PropertyValue.</skos:historyNote>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/Sensor -->

    <owl:Class rdf:about="https://saref.etsi.org/core/Sensor">
        <rdfs:subClassOf rdf:resource="https://saref.etsi.org/core/Device"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/observes"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A device designed to observe and measure one or more properties or states of one or more features of interest.</rdfs:comment>
        <rdfs:label xml:lang="en">Sensor</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Definition of Sensor is simplified and grounded on saref:observes. Local restriction on saref:hasFunction is deleted.</skos:historyNote>
        <skos:historyNote xml:lang="en">V4.1.1: Definition of Sensor and Meter are updated to better distinguish one from the other.</skos:historyNote>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/Service -->

    <owl:Class rdf:about="https://saref.etsi.org/core/Service">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/represents"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://saref.etsi.org/core/Function"/>
                            <rdf:Description rdf:about="https://saref.etsi.org/core/FunctionOfInterest"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/represents"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://saref.etsi.org/core/FunctionOfInterest"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/isOfferedBy"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A saref:Service is a digital representation of a function in a network, making it discoverable, registerable and remotely controllable in the network.</rdfs:comment>
        <rdfs:label xml:lang="en">Service</rdfs:label>
        <skos:example xml:lang="en">For example, a light switch can offer the service of remotely switching the lights in a home through mobile phone devices that are connected to the local network (ex:SwitchOnService class). This &quot;remote switching&quot; service represents the ex:OnOffFunction.</skos:example>
        <skos:historyNote xml:lang="en">V3.2.1: Simplified definition of saref:Service. Added examples.</skos:historyNote>
        <skos:note xml:lang="en">Typically, a device connected to a given network offers one service for each of its functions of interest.</skos:note>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/State -->

    <owl:Class rdf:about="https://saref.etsi.org/core/State">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#broader"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/State"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#narrower"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/State"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Identifiable conditions that features of interest are or may be in, and that can be target of devices, such as observed and controlled. A state can apply to different features of interest.</rdfs:comment>
        <rdfs:label xml:lang="en">State</rdfs:label>
        <skos:example xml:lang="en">A switch can be found in the saref:OnOffState.</skos:example>
        <skos:historyNote xml:lang="en">V3.2.1: Clarified and generalized definition of saref:State. Can now apply to all features of interest, not just devices.</skos:historyNote>
        <skos:note xml:lang="en">Concepts from existing code lists, vocabularies, and taxonomies, may be used as instances of saref:State.</skos:note>
        <skos:note xml:lang="en">SAREF is not restricted to binary states such as the ex:OnOffState, but allows to define also enumerated states.</skos:note>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/StateOfInterest -->

    <owl:Class rdf:about="https://saref.etsi.org/core/StateOfInterest">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://saref.etsi.org/core/isStateOfInterestOf"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Identifiable conditions that features of interest are or may be in, and that can be target of devices, such as observed and controlled. An instance of saref:StateOfInterest is specific to a feature of interest. It is inherent to and cannot exist without that feature of interest.</rdfs:comment>
        <rdfs:label xml:lang="en">State of Interest</rdfs:label>
        <skos:historyNote xml:lang="en">V3.2.1: Introduced saref:StateOfInterest, parallel to saref:PropertyOfInterest.</skos:historyNote>
        <skos:note xml:lang="en">A state of interest is the state of (OP saref:isStateOfInterestOf) exactly one feature of interest.</skos:note>
        <skos:note xml:lang="en">Per convention, the IRI of states of interest should consist of the IRI of their feature of interest, suffixed with a fragment identifier #{S} where {S} refers to the name of the state.</skos:note>
        <skos:note xml:lang="en">States of interest need not always be explicited. It depends on the use case. Typically, states of interest are useful in applications, where the association between a feature of interest and a state (i.e., the state of interest) needs to be identified and related to other states of interest.</skos:note>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/StateValue -->

    <owl:Class rdf:about="https://saref.etsi.org/core/StateValue">
        <rdfs:comment xml:lang="en">Describes the value for a state. The state value is optionally linked the states or states of interest it is a value of (OP saref:isValueOfState).</rdfs:comment>
        <rdfs:label xml:lang="en">State Value</rdfs:label>
        <skos:historyNote xml:lang="en">V4.1.1: Introduced saref:StateValue.</skos:historyNote>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/Task -->

    <owl:Class rdf:about="https://saref.etsi.org/core/Task">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#broader"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/Task"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#narrower"/>
                <owl:allValuesFrom rdf:resource="https://saref.etsi.org/core/Task"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">The goal for which a device is designed, from a user perspective.</rdfs:comment>
        <rdfs:label xml:lang="en">Task</rdfs:label>
        <skos:example xml:lang="en">For example, a washing machine is designed for the task of washing.</skos:example>
        <skos:note xml:lang="en">Tasks can be accomplished by devices (saref:isAccomplishedBy).</skos:note>
    </owl:Class>
    


    <!-- https://saref.etsi.org/core/UnitOfMeasure -->

    <owl:Class rdf:about="https://saref.etsi.org/core/UnitOfMeasure">
        <rdfs:comment xml:lang="en">The unit of measure is a standard for measurement of a quantity, such as a Property.</rdfs:comment>
        <rdfs:label xml:lang="en">Unit of measure</rdfs:label>
        <skos:example xml:lang="en">For example, consumption power is a property and Watt is a unit of power that represents a definite predetermined power: when we say 10 Watt, we actually mean 10 times the definite predetermined power &quot;Watt&quot;.</skos:example>
        <skos:note xml:lang="en">Concepts from existing code lists, vocabularies, and taxonomies, may be used as instances of saref:UnitOfMeasure. For example the QUDT Unit vocabulary</skos:note>
        <skos:note xml:lang="en">Our definition is based on the definition of unit of measure in the Ontology of units of Measure (OM).</skos:note>
    </owl:Class>
    


    <!-- https://saref.etsi.org/saref4syst/System -->

    <owl:Class rdf:about="https://saref.etsi.org/saref4syst/System"/>
</rdf:RDF>



